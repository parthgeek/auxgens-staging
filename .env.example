# Gmail SMTP requires 2-Step Verification and a 16-character app password:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@your-domain.com
SMTP_PASS=replace-with-16-character-app-password
SMTP_FROM=Auxgens <contact@your-domain.com>
CONTACT_TO=contact@your-domain.com
